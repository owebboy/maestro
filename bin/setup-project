#!/usr/bin/env bash
set -euo pipefail

shopt -s nullglob

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd -P)"

INSTALL_CLAUDE=false
INSTALL_CODEX=false
SETUP_MAESTRO=true
SETUP_HOOKS=true
INSTALL_MODE="symlink"
TARGET_DIR=""
EXPLICIT_HARNESS=false
HARNESS_SOURCE="explicit"
LEGACY_DETECTED=false

print_help() {
  cat <<'EOF'
Usage: setup-project [options] [target-dir]

Installs Maestro into another project for Claude Code, Codex, or both.
Install Superpowers separately via its official installer if you want it.

If no harness is selected, the script auto-detects from the target project.
If no Claude/Codex markers are found, it defaults to installing both.

Options:
  --claude             Install for Claude Code (.claude/skills/)
  --codex              Install for Codex (.agents/skills/)
  --both               Install for both harnesses
  --copy, --portable   Copy files instead of creating symlinks
  --symlink            Create symlinks (default)
  --no-maestro         Do not create .maestro/ scaffolding
  --no-issues          Alias for --no-maestro (back-compat)
  --no-hooks           Do not install hook scripts/config
  --help, -h           Show this help

Examples:
  setup-project
  setup-project /path/to/project
  setup-project --portable /path/to/project
  setup-project --codex /path/to/project
EOF
}

fail() {
  echo "Error: $*" >&2
  exit 1
}

section() {
  echo "=== $1 ==="
}

note() {
  echo "  $1"
}

destination_exists() {
  local path="$1"
  [[ -e "$path" || -L "$path" ]]
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --claude)
        INSTALL_CLAUDE=true
        EXPLICIT_HARNESS=true
        shift
        ;;
      --codex)
        INSTALL_CODEX=true
        EXPLICIT_HARNESS=true
        shift
        ;;
      --both)
        INSTALL_CLAUDE=true
        INSTALL_CODEX=true
        EXPLICIT_HARNESS=true
        shift
        ;;
      --copy|--portable)
        INSTALL_MODE="copy"
        shift
        ;;
      --symlink)
        INSTALL_MODE="symlink"
        shift
        ;;
      --no-maestro)
        SETUP_MAESTRO=false
        shift
        ;;
      --no-issues)
        SETUP_MAESTRO=false
        shift
        ;;
      --no-hooks)
        SETUP_HOOKS=false
        shift
        ;;
      --help|-h)
        print_help
        exit 0
        ;;
      --*)
        fail "Unknown option: $1"
        ;;
      *)
        if [[ -n "$TARGET_DIR" ]]; then
          fail "Only one target directory may be provided"
        fi
        TARGET_DIR="$1"
        shift
        ;;
    esac
  done
}

resolve_target_dir() {
  local requested_dir="${TARGET_DIR:-.}"
  mkdir -p "$requested_dir"
  TARGET_DIR="$(CDPATH= cd -- "$requested_dir" && pwd -P)"
}

auto_select_harnesses() {
  if $EXPLICIT_HARNESS; then
    HARNESS_SOURCE="explicit"
    return
  fi

  local found_claude=false
  local found_codex=false

  if [[ -d "$TARGET_DIR/.claude" || -f "$TARGET_DIR/.claude/settings.json" || -f "$TARGET_DIR/CLAUDE.md" ]]; then
    found_claude=true
  fi

  if [[ -d "$TARGET_DIR/.agents" || -d "$TARGET_DIR/.codex" || -f "$TARGET_DIR/.codex/config.toml" || -f "$TARGET_DIR/AGENTS.md" ]]; then
    found_codex=true
  fi

  if $found_claude; then
    INSTALL_CLAUDE=true
  fi

  if $found_codex; then
    INSTALL_CODEX=true
  fi

  if ! $INSTALL_CLAUDE && ! $INSTALL_CODEX; then
    INSTALL_CLAUDE=true
    INSTALL_CODEX=true
    HARNESS_SOURCE="defaulted to both"
    return
  fi

  HARNESS_SOURCE="auto-detected"
}

print_summary() {
  echo "maestro setup"
  note "Target:      $TARGET_DIR"
  note "Plugin:      $SCRIPT_DIR"
  note "Mode:        $INSTALL_MODE"
  note "Claude:      $INSTALL_CLAUDE"
  note "Codex:       $INSTALL_CODEX"
  note "Maestro:     $SETUP_MAESTRO"
  note "Hooks:       $SETUP_HOOKS"
  note "Harnesses:   $HARNESS_SOURCE"
  echo ""
}

install_path() {
  local src="$1"
  local dest="$2"

  if destination_exists "$dest"; then
    note "skip: $(basename "$dest") (already exists)"
    return
  fi

  if [[ "$INSTALL_MODE" == "copy" ]]; then
    cp -R "$src" "$dest"
    note "copy: $(basename "$dest")"
  else
    ln -s "$src" "$dest"
    note "link: $(basename "$dest") -> $src"
  fi
}

install_skill_set() {
  local source_root="$1"
  local dest_dir="$2"
  local count=0
  local skill_dir

  mkdir -p "$dest_dir"

  for skill_dir in "$source_root"/*; do
    [[ -d "$skill_dir" ]] || continue
    install_path "$skill_dir" "$dest_dir/$(basename "$skill_dir")"
    count=$((count + 1))
  done

  if [[ $count -eq 0 ]]; then
    note "skip: no skills found in $source_root"
  fi
}

install_claude_skills() {
  section "Claude Code"
  install_skill_set "$SCRIPT_DIR/skills" "$TARGET_DIR/.claude/skills"
  echo ""
}

install_codex_skills() {
  section "Codex"
  install_skill_set "$SCRIPT_DIR/skills" "$TARGET_DIR/.agents/skills"
  echo ""
}

write_inbox_file() {
  local inbox_path="$1"

  cat > "$inbox_path" <<'EOF'
# Inbox

Add work items as bullet points below. Run `/triage` in Claude Code or `$triage` in Codex to process them.

## Format

```
- <description>
- <description> (type: bug, priority: P1)
```

Type and priority are optional — triage will infer them.

**Types:** bug | feature | refactor | chore
**Priorities:** P1 (blocking) | P2 (important) | P3 (nice-to-have)

## Inbox

EOF
}

ensure_directory() {
  local dir_path="$1"
  local label="$2"

  if [[ -d "$dir_path" ]]; then
    note "ok: $label"
  else
    mkdir -p "$dir_path"
    note "created: $label"
  fi
}

ensure_maestro_scaffold() {
  local maestro_dir="$TARGET_DIR/.maestro"
  local assets_src="$SCRIPT_DIR/assets/maestro"
  local inbox_path="$maestro_dir/inbox.md"
  local config_path="$maestro_dir/config.json"

  if ! $SETUP_MAESTRO; then
    return
  fi

  section ".maestro/ Directory"

  # Core directories (LD-1)
  ensure_directory "$maestro_dir" ".maestro/"
  ensure_directory "$maestro_dir/context" ".maestro/context/"
  ensure_directory "$maestro_dir/context/styleguides" ".maestro/context/styleguides/"
  ensure_directory "$maestro_dir/work" ".maestro/work/"
  ensure_directory "$maestro_dir/items" ".maestro/items/"
  ensure_directory "$maestro_dir/items/archived/done" ".maestro/items/archived/done/"
  ensure_directory "$maestro_dir/items/archived/wont-fix" ".maestro/items/archived/wont-fix/"
  ensure_directory "$maestro_dir/items/archived/deferred" ".maestro/items/archived/deferred/"
  ensure_directory "$maestro_dir/items/archived/duplicate" ".maestro/items/archived/duplicate/"

  # Package-managed assets: overwrite on each setup (LD-2)
  if [[ -f "$assets_src/CONTRACT.md" ]]; then
    cp "$assets_src/CONTRACT.md" "$maestro_dir/CONTRACT.md"
    note "copy: .maestro/CONTRACT.md (package-managed)"
  fi

  if [[ -d "$assets_src/adapters" ]]; then
    mkdir -p "$maestro_dir/adapters"
    cp -R "$assets_src/adapters/." "$maestro_dir/adapters/"
    note "copy: .maestro/adapters/ (package-managed)"
  fi

  # Project-owned assets: only if missing (LD-1)
  if [[ -f "$config_path" ]]; then
    note "ok: .maestro/config.json"
  elif [[ -f "$assets_src/config.template.json" ]]; then
    cp "$assets_src/config.template.json" "$config_path"
    note "created: .maestro/config.json (from template)"
  fi

  if [[ -f "$inbox_path" ]]; then
    note "ok: .maestro/inbox.md"
  else
    write_inbox_file "$inbox_path"
    note "created: .maestro/inbox.md"
  fi

  echo ""
}

copy_hook_script() {
  local src="$1"
  local dest_dir="$2"
  local dest_path="$dest_dir/$(basename "$src")"

  mkdir -p "$dest_dir"

  if destination_exists "$dest_path"; then
    note "skip: $(basename "$src") (already exists)"
    return
  fi

  cp "$src" "$dest_path"
  chmod +x "$dest_path"
  note "copy: $(basename "$src") -> ${dest_dir#$TARGET_DIR/}/"
}

write_claude_settings_with_hooks() {
  local settings_path="$1"

  cat > "$settings_path" <<'EOF'
{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/session-start-maestro.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/validate-item-frontmatter.sh" }
        ]
      }
    ]
  }
}
EOF
}

print_claude_hook_snippet() {
  cat <<'EOF'
  Add to .claude/settings.json:
  {
    "hooks": {
      "SessionStart": [
        { "hooks": [{ "type": "command", "command": ".claude/hooks/session-start-maestro.sh" }] }
      ],
      "PostToolUse": [
        { "matcher": "Write|Edit", "hooks": [{ "type": "command", "command": ".claude/hooks/validate-item-frontmatter.sh" }] }
      ]
    }
  }
EOF
}

install_claude_hooks() {
  local hooks_src="$SCRIPT_DIR/bin/hooks"
  local hooks_dest="$TARGET_DIR/.claude/hooks"
  local settings_path="$TARGET_DIR/.claude/settings.json"
  local hook_script

  [[ -d "$hooks_src" ]] || return

  section "Claude Hooks"

  for hook_script in "$hooks_src"/*.sh; do
    [[ -f "$hook_script" ]] || continue
    copy_hook_script "$hook_script" "$hooks_dest"
  done

  mkdir -p "$(dirname "$settings_path")"
  if [[ -f "$settings_path" ]]; then
    note "skip: .claude/settings.json already exists"
    print_claude_hook_snippet
  else
    write_claude_settings_with_hooks "$settings_path"
    note "created: .claude/settings.json (hooks enabled)"
  fi

  echo ""
}

write_codex_hooks_json() {
  local hooks_json_path="$1"

  cat > "$hooks_json_path" <<'EOF'
{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": ".codex/hooks/session-start-maestro.sh" }
        ]
      }
    ]
  }
}
EOF
}

print_codex_hook_snippet() {
  cat <<'EOF'
  Add to .codex/hooks.json:
  {
    "hooks": {
      "SessionStart": [
        { "hooks": [{ "type": "command", "command": ".codex/hooks/session-start-maestro.sh" }] }
      ]
    }
  }
EOF
}

install_codex_hooks() {
  local hooks_src="$SCRIPT_DIR/bin/hooks"
  local hooks_dest="$TARGET_DIR/.codex/hooks"
  local hooks_json="$TARGET_DIR/.codex/hooks.json"
  local session_start_hook="$hooks_src/session-start-maestro.sh"

  [[ -f "$session_start_hook" ]] || return

  section "Codex Hooks"
  copy_hook_script "$session_start_hook" "$hooks_dest"

  if [[ -f "$hooks_json" ]]; then
    note "skip: .codex/hooks.json already exists"
    print_codex_hook_snippet
  else
    write_codex_hooks_json "$hooks_json"
    note "created: .codex/hooks.json (session-start hook registered)"
  fi
  note "note: Codex hooks are on by default; disable with [features] hooks = false"
  echo ""
}

install_hooks() {
  if ! $SETUP_HOOKS; then
    return
  fi

  if $INSTALL_CLAUDE; then
    install_claude_hooks
  fi

  if $INSTALL_CODEX; then
    install_codex_hooks
  fi
}

print_codex_tip() {
  if ! $INSTALL_CODEX || [[ -f "$TARGET_DIR/AGENTS.md" ]]; then
    return
  fi

  section "Codex Tip"
  note "No AGENTS.md found"
  note 'Run $agents-md-sync in Codex or /agents-md-sync in Claude Code'
  note 'to generate one from your CLAUDE.md'
  echo ""
  note "Optional ~/.codex/config.toml fallback (global, top-level key):"
  note 'project_doc_fallback_filenames = ["CLAUDE.md"]'
  echo ""
}

print_next_steps() {
  echo "Done."
  if $INSTALL_CLAUDE && $INSTALL_CODEX; then
    echo 'Run /setup in Claude Code or $setup in Codex to initialize .maestro/ context, then /triage or $triage to process inbox items.'
  elif $INSTALL_CLAUDE; then
    echo 'Run /setup in Claude Code to initialize .maestro/ context, then /triage to process inbox items.'
  else
    echo 'Run $setup in Codex to initialize .maestro/ context, then $triage to process inbox items.'
  fi
  if $LEGACY_DETECTED; then
    echo ""
    echo "To migrate legacy data: $SCRIPT_DIR/bin/migrate-to-maestro --path \"$TARGET_DIR\" --apply"
  fi
}

detect_legacy() {
  if { [[ -d "$TARGET_DIR/conductor" ]] || [[ -d "$TARGET_DIR/issues" ]]; } && [[ ! -d "$TARGET_DIR/.maestro" ]]; then
    LEGACY_DETECTED=true
    echo ""
    echo "Legacy conductor/ or issues/ detected and no .maestro/ yet."
    echo "Preview migration:  $SCRIPT_DIR/bin/migrate-to-maestro --path \"$TARGET_DIR\""
    echo "Apply migration:    $SCRIPT_DIR/bin/migrate-to-maestro --path \"$TARGET_DIR\" --apply"
    echo ""
  fi
}

main() {
  parse_args "$@"
  resolve_target_dir
  detect_legacy
  auto_select_harnesses
  print_summary

  if $INSTALL_CLAUDE; then
    install_claude_skills
  fi

  if $INSTALL_CODEX; then
    install_codex_skills
  fi

  ensure_maestro_scaffold
  install_hooks
  print_codex_tip
  print_next_steps
}

main "$@"
