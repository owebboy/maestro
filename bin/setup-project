#!/usr/bin/env bash
set -euo pipefail

# maestro: project-scoped setup for Codex
#
# Usage:
#   setup-project [--with-superpowers] [target-dir]

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
WITH_SUPERPOWERS=false
TARGET_DIR=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --with-superpowers) WITH_SUPERPOWERS=true; shift ;;
    --help|-h)
      echo "Usage: setup-project [--with-superpowers] [target-dir]"
      echo ""
      echo "Options:"
      echo "  --with-superpowers  Also install Superpowers from ~/.codex/superpowers/skills if available"
      echo "  target-dir          Project directory (default: current directory)"
      exit 0
      ;;
    *) TARGET_DIR="$1"; shift ;;
  esac
done

TARGET_DIR="${TARGET_DIR:-.}"
TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"

echo "maestro setup"
echo "  Target:      $TARGET_DIR"
echo "  Codex:       true"
echo "  Superpowers: $WITH_SUPERPOWERS"
echo ""

symlink_skill() {
  local src="$1" dest_dir="$2" name="$3"
  mkdir -p "$dest_dir"
  local dest="$dest_dir/$name"
  if [[ -e "$dest" ]]; then
    echo "  skip: $name (already exists)"
  else
    ln -s "$src" "$dest"
    echo "  link: $name -> $src"
  fi
}

echo "=== Codex ==="
CODEX_SKILLS="$TARGET_DIR/.agents/skills"

for skill_dir in "$SCRIPT_DIR/skills"/*/; do
  skill_name="$(basename "$skill_dir")"
  symlink_skill "$skill_dir" "$CODEX_SKILLS" "$skill_name"
done

echo ""

if $WITH_SUPERPOWERS; then
  echo "=== Superpowers ==="
  SUPERPOWERS_SRC="$HOME/.codex/superpowers/skills"
  if [[ -d "$SUPERPOWERS_SRC" ]]; then
    for skill_dir in "$SUPERPOWERS_SRC"/*/; do
      skill_name="$(basename "$skill_dir")"
      symlink_skill "$skill_dir" "$CODEX_SKILLS" "$skill_name"
    done
  else
    echo "  not found at $SUPERPOWERS_SRC"
    echo "  install Superpowers for Codex or continue with Maestro inline fallbacks"
  fi
  echo ""
fi

if [[ ! -d "$TARGET_DIR/issues" ]]; then
  echo "=== Issues Directory ==="
  echo "  skip: issues/ is not created automatically in non-interactive setup"
  echo ""
fi

HOOKS_SRC="$SCRIPT_DIR/bin/hooks"
if [[ -d "$HOOKS_SRC" ]]; then
  echo "=== Hooks ==="
  CODEX_HOOKS="$TARGET_DIR/.agents/hooks"
  mkdir -p "$CODEX_HOOKS"
  if [[ -e "$CODEX_HOOKS/session-start-issues.sh" ]]; then
    echo "  skip: session-start-issues.sh (already exists)"
  else
    cp "$HOOKS_SRC/session-start-issues.sh" "$CODEX_HOOKS/session-start-issues.sh"
    chmod +x "$CODEX_HOOKS/session-start-issues.sh"
    echo "  copy: session-start-issues.sh -> .agents/hooks/"
  fi
  echo ""
fi

if [[ ! -f "$TARGET_DIR/AGENTS.md" ]]; then
  echo "=== Codex Tip ==="
  echo "  No AGENTS.md found. Create one for persistent project instructions."
  echo ""
fi

echo "Done. Run /setup in your project to initialize conductor/ context."
